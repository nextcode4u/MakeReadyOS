generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  TECH
  LEASING
  CLEANER
  VIEWER
}

enum CustomFieldType {
  TEXT
  LONG_TEXT
  NUMBER
  DATE
  SINGLE_SELECT
  MULTI_SELECT
  BOOLEAN
  USER
}

model Property {
  id                        String                                @id @default(cuid())
  name                      String
  code                      String                                @unique
  occupancyGoalPercent      Float?
  uploadStorageMode         String                                @default("DEFAULT")
  uploadSubdir              String?
  isActive                  Boolean                               @default(true)
  createdAt                 DateTime                              @default(now())
  updatedAt                 DateTime                              @updatedAt
  units                     Unit[]
  floorPlans                FloorPlan[]
  makeReadyItems            MakeReadyItem[]
  refrigerantLogs           RefrigerantLog[]
  poolFacilities            PoolFacility[]
  poolChemicals             PoolChemical[]
  poolChemistryTargets      PoolChemistryTarget[]
  poolLogEntries            PoolLogEntry[]
  poolLogAttachments        PoolLogAttachment[]
  poolChemicalLogs          PoolChemicalLog[]
  pmTemplates               PreventiveMaintenanceTemplate[]
  pmTasks                   PreventiveMaintenanceTask[]
  pmTaskAttachments         PreventiveMaintenanceTaskAttachment[]
  projectRecords            ProjectRecord[]
  projectAttachments        ProjectAttachment[]
  projectComments           ProjectComment[]
  projectTasks              ProjectTask[]
  projectCategories         ProjectCategory[]
  projectWikiReferences     ProjectWikiReference[]
  leaseComplianceIssueTypes LeaseComplianceIssueType[]
  leaseComplianceSettings   LeaseComplianceSettings?
  leaseComplianceIssues     LeaseComplianceIssue[]
  leaseComplianceNotes      LeaseComplianceIssueNote[]
  leaseCompliancePhotos     LeaseComplianceIssuePhoto[]
  leaseComplianceNotices    LeaseComplianceNoticeAction[]
  leaseComplianceChecks     LeaseCompliancePersistenceCheck[]
  wikiProfile               PropertyWikiProfile?
  wikiEntries               PropertyWikiEntry[]
  wikiVendors               PropertyWikiVendor[]
  wikiAssets                PropertyWikiAsset[]
  wikiFavorites             PropertyWikiFavorite[]
  wikiRecentViews           PropertyWikiRecentView[]
  wikiReferences            PropertyWikiReference[]
  pestIssues                PestIssue[]
  pestVendors               PestVendor[]
  pestIssueNotes            PestIssueNote[]
  pestAttachments           PestIssueAttachment[]
  notes                     PropertyNote[]
  checklistTemplates        ChecklistTemplate[]
  checklistInstances        ChecklistInstance[]
  itemComments              ItemComment[]
  itemAttachments           ItemAttachment[]
  chargePriceSheetItems     ChargePriceSheetItem[]
  vendorServiceAreas        VendorServiceArea[]
  vendorAssignments         VendorAssignment[]
  workAssignmentBlocks      WorkAssignmentBlock[]
  propertyMaps              PropertyMap[]
  propertyMapAreas          PropertyMapArea[]
  propertyMapPins           PropertyMapPin[]
  propertyMapPinAttachments PropertyMapPinAttachment[]
  unitMapLocations          UnitMapLocation[]
  dailyMetricSnapshots      PropertyDailyMetricSnapshot[]
  userAccess                UserPropertyAccess[]
  auditLogs                 AuditLog[]
  automationRules           AutomationRule[]
  boardSections             BoardSection[]
  operatingCalendar         OperatingCalendar?
  riskPolicy                PropertyRiskPolicy?
  notifications             Notification[]
  notificationPreferences   NotificationPreference[]
  apiTokenScopes            ApiTokenPropertyScope[]
  webhookScopes             WebhookPropertyScope[]
}

model Unit {
  id              String            @id @default(cuid())
  propertyId      String
  property        Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  floorPlanId     String?
  floorPlanRecord FloorPlan?        @relation(fields: [floorPlanId], references: [id], onDelete: SetNull)
  number          String
  floorPlan       String?
  squareFeet      Int?
  bedrooms        Int?
  bathrooms       Float?
  occupancyStatus String            @default("OCCUPIED")
  building        String?
  area            String?
  floor           String?
  isBudgeted      Boolean           @default(true)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  makeReadyItems  MakeReadyItem[]
  pestIssues      PestIssue[]
  leaseComplianceIssues LeaseComplianceIssue[]
  mapLocations    UnitMapLocation[]

  @@unique([propertyId, number])
  @@index([floorPlanId])
  @@index([propertyId, occupancyStatus])
  @@index([propertyId, building])
}

model FloorPlan {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  code        String
  name        String
  bedrooms    Int?
  bathrooms   Float?
  squareFeet  Int?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  units       Unit[]

  @@unique([propertyId, code])
  @@index([propertyId, isActive, code])
  @@index([propertyId, name])
}

model MakeReadyItem {
  id                   String                @id @default(cuid())
  propertyId           String
  unitId               String?
  property             Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit                 Unit?                 @relation(fields: [unitId], references: [id], onDelete: SetNull)
  boardGroup           String
  itemName             String
  unitNumber           String
  floorPlan            String?
  applicant            String?
  assignedTech         String?
  scopeLevel           String?
  status               String                @default("ACTIVE")
  vacancyStatus        String?
  moveOutDate          DateTime?
  vacatedDate          DateTime?
  makeReadyDate        DateTime?
  moveInDate           DateTime?
  daysVacant           Int                   @default(0)
  daysUntilMoveIn      Int?
  priority             Int                   @default(0)
  overdue              Boolean               @default(false)
  moveInSoon           Boolean               @default(false)
  riskScore            Int                   @default(0)
  riskLevel            String                @default("NONE")
  riskReasons          Json                  @default("[]")
  lastRiskEvaluatedAt  DateTime?
  completionStatus     String?
  sheetrockStatus      String?
  pestStatus           String?
  pestTreated          String?
  trashOutStatus       String?
  floorsStatus         String?
  flooringDate         DateTime?
  makeReadyStatus      String?
  cleaningStatus       String?
  keysMadeStatus       String?
  cabinetsStatus       String?
  countertopsStatus    String?
  appliancesStatus     String?
  paintStatus          String?
  doorsStatus          String?
  newDoorCode          String?
  notes                String?
  isArchived           Boolean               @default(false)
  archivedAt           DateTime?
  lastAutomationAt     DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  automationRuns       AutomationRun[]
  automationCooldowns  AutomationCooldown[]
  customFieldValues    CustomFieldValue[]
  notifications        Notification[]
  comments             ItemComment[]
  attachments          ItemAttachment[]
  checklistInstances   ChecklistInstance[]
  vendorAssignments    VendorAssignment[]
  workAssignmentBlocks WorkAssignmentBlock[]
  pestIssues           PestIssue[]

  @@index([propertyId, boardGroup])
  @@index([propertyId, isArchived, boardGroup])
  @@index([unitId])
  @@index([propertyId, isArchived, assignedTech])
  @@index([propertyId, isArchived, vacancyStatus])
  @@index([propertyId, isArchived, updatedAt])
  @@index([propertyId, isArchived, riskLevel])
  @@index([propertyId, isArchived, riskScore])
  @@index([propertyId, isArchived, moveInDate])
  @@index([moveInDate])
  @@index([makeReadyDate])
}

model User {
  id                           String                                @id @default(cuid())
  username                     String                                @unique
  email                        String?                               @unique
  passwordHash                 String
  fullName                     String
  role                         UserRole
  language                     String                                @default("en")
  isActive                     Boolean                               @default(true)
  createdAt                    DateTime                              @default(now())
  updatedAt                    DateTime                              @updatedAt
  sessions                     Session[]
  propertyAccess               UserPropertyAccess[]
  auditLogs                    AuditLog[]
  savedViews                   SavedView[]
  notifications                Notification[]
  notificationPreferences      NotificationPreference[]
  notificationSettings         UserNotificationSettings?
  capacity                     UserCapacity?
  workAssignments              WorkAssignmentBlock[]
  comments                     ItemComment[]
  attachments                  ItemAttachment[]
  poolLogAttachments           PoolLogAttachment[]
  wikiProfilesCreated          PropertyWikiProfile[]                 @relation("PropertyWikiProfileCreatedBy")
  wikiProfilesUpdated          PropertyWikiProfile[]                 @relation("PropertyWikiProfileUpdatedBy")
  wikiEntriesCreated           PropertyWikiEntry[]                   @relation("PropertyWikiEntryCreatedBy")
  wikiEntriesUpdated           PropertyWikiEntry[]                   @relation("PropertyWikiEntryUpdatedBy")
  wikiVendorsCreated           PropertyWikiVendor[]                  @relation("PropertyWikiVendorCreatedBy")
  wikiVendorsUpdated           PropertyWikiVendor[]                  @relation("PropertyWikiVendorUpdatedBy")
  wikiAssetsCreated            PropertyWikiAsset[]                   @relation("PropertyWikiAssetCreatedBy")
  wikiFavorites                PropertyWikiFavorite[]
  wikiRecentViews              PropertyWikiRecentView[]
  wikiReferencesCreated        PropertyWikiReference[]
  pmTemplatesCreated           PreventiveMaintenanceTemplate[]       @relation("PreventiveMaintenanceTemplateCreatedBy")
  pmTemplatesUpdated           PreventiveMaintenanceTemplate[]       @relation("PreventiveMaintenanceTemplateUpdatedBy")
  pmTasksCompleted             PreventiveMaintenanceTask[]           @relation("PreventiveMaintenanceTaskCompletedBy")
  pmTaskAttachments            PreventiveMaintenanceTaskAttachment[]
  projectsCreated              ProjectRecord[]                       @relation("ProjectRecordCreatedBy")
  projectsUpdated              ProjectRecord[]                       @relation("ProjectRecordUpdatedBy")
  projectsCompleted            ProjectRecord[]                       @relation("ProjectRecordCompletedBy")
  projectAttachments           ProjectAttachment[]
  projectComments              ProjectComment[]
  projectTasksAssigned         ProjectTask[]                         @relation("ProjectTaskAssignedUser")
  projectTasksCompleted        ProjectTask[]                         @relation("ProjectTaskCompletedBy")
  projectWikiReferencesCreated ProjectWikiReference[]
  propertyMapPinsCreated       PropertyMapPin[]                      @relation("PropertyMapPinCreatedBy")
  propertyMapPinsUpdated       PropertyMapPin[]                      @relation("PropertyMapPinUpdatedBy")
  propertyMapPinAttachments    PropertyMapPinAttachment[]
  leaseComplianceIssueTypesCreated LeaseComplianceIssueType[]      @relation("LeaseComplianceIssueTypeCreatedBy")
  leaseComplianceIssueTypesUpdated LeaseComplianceIssueType[]      @relation("LeaseComplianceIssueTypeUpdatedBy")
  leaseComplianceIssuesCreated LeaseComplianceIssue[]              @relation("LeaseComplianceIssueCreatedBy")
  leaseComplianceIssuesUpdated LeaseComplianceIssue[]              @relation("LeaseComplianceIssueUpdatedBy")
  leaseComplianceIssuesAssigned LeaseComplianceIssue[]             @relation("LeaseComplianceIssueAssignedUser")
  leaseComplianceIssuesResolved LeaseComplianceIssue[]             @relation("LeaseComplianceIssueResolvedBy")
  leaseComplianceIssuesArchived LeaseComplianceIssue[]             @relation("LeaseComplianceIssueArchivedBy")
  leaseComplianceSettingsUpdated LeaseComplianceSettings[]         @relation("LeaseComplianceSettingsUpdatedBy")
  leaseComplianceNotes         LeaseComplianceIssueNote[]
  leaseCompliancePhotos        LeaseComplianceIssuePhoto[]
  leaseComplianceNoticeActions LeaseComplianceNoticeAction[]
  leaseComplianceChecks        LeaseCompliancePersistenceCheck[]
  pestIssuesCreated            PestIssue[]                           @relation("PestIssueCreatedBy")
  pestIssuesUpdated            PestIssue[]                           @relation("PestIssueUpdatedBy")
  pestIssuesAssigned           PestIssue[]                           @relation("PestIssueAssignedUser")
  pestIssuesClosed             PestIssue[]                           @relation("PestIssueClosedBy")
  pestIssuesArchived           PestIssue[]                           @relation("PestIssueArchivedBy")
  pestIssueNotes               PestIssueNote[]
  pestAttachments              PestIssueAttachment[]
  pestVendorsCreated           PestVendor[]                          @relation("PestVendorCreatedBy")
  pestVendorsUpdated           PestVendor[]                          @relation("PestVendorUpdatedBy")
  completedChecklistItems      ChecklistInstanceItem[]
  apiTokensCreated             ApiToken[]
  webhooksCreated              WebhookEndpoint[]
}

model ApiToken {
  id             String                  @id @default(cuid())
  name           String
  tokenHash      String                  @unique
  tokenPrefix    String
  tokenLastFour  String
  createdById    String
  createdBy      User                    @relation(fields: [createdById], references: [id], onDelete: Cascade)
  scopes         String[]
  isActive       Boolean                 @default(true)
  revokedAt      DateTime?
  useCount       Int                     @default(0)
  lastUsedAt     DateTime?
  lastUsedPath   String?
  lastUsedMethod String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  propertyScopes ApiTokenPropertyScope[]
  rateLimitWindows ApiTokenRateLimitWindow[]

  @@index([createdById, isActive])
  @@index([tokenPrefix])
}

model ApiTokenPropertyScope {
  id         String   @id @default(cuid())
  apiTokenId String
  propertyId String
  apiToken   ApiToken @relation(fields: [apiTokenId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([apiTokenId, propertyId])
  @@index([propertyId])
}

model ApiTokenRateLimitWindow {
  id              String   @id @default(cuid())
  apiTokenId      String
  apiToken        ApiToken @relation(fields: [apiTokenId], references: [id], onDelete: Cascade)
  windowStartedAt DateTime
  requestCount    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([apiTokenId, windowStartedAt])
  @@index([windowStartedAt])
}

model WebhookEndpoint {
  id               String                   @id @default(cuid())
  name             String
  url              String
  secretHash       String
  secretCiphertext String?
  secretLastFour   String
  eventTypes       String[]
  isEnabled        Boolean                  @default(true)
  createdById      String
  createdBy        User                     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  lastDeliveryAt   DateTime?
  failureCount     Int                      @default(0)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  propertyScopes   WebhookPropertyScope[]
  deliveryAttempts WebhookDeliveryAttempt[]

  @@index([createdById, isEnabled])
}

model WebhookDeliveryAttempt {
  id             String          @id @default(cuid())
  webhookId      String
  webhook        WebhookEndpoint @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  eventType      String
  status         String          @default("PENDING")
  deliveryId     String          @unique
  payload        Json
  headers        Json?
  attemptNumber  Int             @default(1)
  responseStatus Int?
  responseBody   String?
  errorMessage   String?
  nextAttemptAt  DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([webhookId, createdAt])
  @@index([status, nextAttemptAt])
}

model WebhookPropertyScope {
  id         String          @id @default(cuid())
  webhookId  String
  propertyId String
  webhook    WebhookEndpoint @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  property   Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@unique([webhookId, propertyId])
  @@index([propertyId])
}

model Vendor {
  id                 String              @id @default(cuid())
  name               String
  trade              String
  phone              String?
  email              String?
  notes              String?
  isActive           Boolean             @default(true)
  isPreferred        Boolean             @default(false)
  insuranceExpiresAt DateTime?
  licenseExpiresAt   DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  contacts           VendorContact[]
  serviceAreas       VendorServiceArea[]
  assignments        VendorAssignment[]

  @@index([isActive, trade, name])
  @@index([isPreferred, trade])
}

model VendorContact {
  id        String   @id @default(cuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name      String
  role      String?
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId, name])
}

model VendorServiceArea {
  id         String   @id @default(cuid())
  vendorId   String
  propertyId String
  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([vendorId, propertyId])
  @@index([propertyId])
}

model VendorAssignment {
  id            String        @id @default(cuid())
  vendorId      String
  vendor        Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  propertyId    String
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  itemId        String
  item          MakeReadyItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  trade         String
  status        String        @default("REQUESTED")
  scheduledDate DateTime?
  dueDate       DateTime?
  completedAt   DateTime?
  notes         String?
  costEstimate  Float?
  invoiceRef    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([propertyId, status, dueDate])
  @@index([itemId, status])
  @@index([vendorId, status])
  @@index([scheduledDate])
  @@index([dueDate])
}

model UserCapacity {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultDailyHours Float    @default(8)
  tradeCategories   String[] @default([])
  unavailableDays   Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([defaultDailyHours])
}

model WorkAssignmentBlock {
  id             String        @id @default(cuid())
  assignedUserId String
  assignedUser   User          @relation(fields: [assignedUserId], references: [id], onDelete: Cascade)
  propertyId     String
  property       Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  itemId         String
  item           MakeReadyItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  category       String
  plannedDate    DateTime
  estimatedHours Float         @default(1)
  actualHours    Float?
  status         String        @default("PLANNED")
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([propertyId, plannedDate])
  @@index([assignedUserId, plannedDate])
  @@index([itemId, status])
  @@index([status, plannedDate])
}

model PropertyMap {
  id             String            @id @default(cuid())
  propertyId     String
  property       Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name           String
  mapType        String            @default("Custom")
  originalName   String?
  storedName     String?
  mimeType       String?
  sizeBytes      Int?
  width          Int?
  height         Int?
  description    String?
  notes          String?
  isDefault      Boolean           @default(false)
  isActive       Boolean           @default(true)
  isArchived     Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  locations      UnitMapLocation[]
  areas          PropertyMapArea[]
  pins           PropertyMapPin[]
  projectRecords ProjectRecord[]
  leaseComplianceIssues LeaseComplianceIssue[]

  @@index([propertyId, isActive, isArchived])
  @@index([propertyId, mapType, isArchived])
}

model LeaseComplianceIssueType {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String
  color      String?  @default("#58a6de")
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdById String?
  createdBy   User?   @relation("LeaseComplianceIssueTypeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?   @relation("LeaseComplianceIssueTypeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  issues     LeaseComplianceIssue[]

  @@unique([propertyId, name])
  @@index([propertyId, isActive, sortOrder])
}

model LeaseComplianceSettings {
  id                    String   @id @default(cuid())
  propertyId            String   @unique
  property              Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  defaultPriority       String   @default("Normal")
  watchDays             Int      @default(3)
  warningDays           Int      @default(7)
  criticalDays          Int      @default(14)
  firstNoticeLabel      String   @default("1st Notice Sent")
  secondNoticeLabel     String   @default("2nd Notice Sent")
  thirdNoticeLabel      String   @default("3rd Notice Sent")
  archiveResolvedAfterDays Int?
  updatedById           String?
  updatedBy             User?    @relation("LeaseComplianceSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model LeaseComplianceIssue {
  id                    String   @id @default(cuid())
  propertyId            String
  property              Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unitId                String?
  unit                  Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)
  issueTypeId           String?
  issueType             LeaseComplianceIssueType? @relation(fields: [issueTypeId], references: [id], onDelete: SetNull)
  propertyMapId         String?
  propertyMap           PropertyMap? @relation(fields: [propertyMapId], references: [id], onDelete: SetNull)
  building              String?
  area                  String?
  issueTypeName         String
  additionalIssueType   String?
  status                String   @default("Open")
  noticeStage           String   @default("None")
  priority              String   @default("Normal")
  source                String   @default("Property Walk")
  description           String?
  locationNotes         String?
  tags                  String[] @default([])
  assignedUserId        String?
  assignedUser          User?    @relation("LeaseComplianceIssueAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedUserName      String?
  lastPersistenceCheckDate DateTime?
  daysOpenOverride      Int?
  persistenceCount      Int      @default(0)
  residentNotifiedDate  DateTime?
  notice1Date           DateTime?
  notice2Date           DateTime?
  notice3Date           DateTime?
  violationNeededDate   DateTime?
  recurringConcern      Boolean  @default(false)
  managerReviewRequired Boolean  @default(false)
  recurringDismissedAt  DateTime?
  recurringDismissalNotes String?
  resolvedDate          DateTime?
  resolvedById          String?
  resolvedBy            User?    @relation("LeaseComplianceIssueResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolutionNotes       String?
  isArchived            Boolean  @default(false)
  archiveDate           DateTime?
  archivedById          String?
  archivedBy            User?    @relation("LeaseComplianceIssueArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)
  archiveNotes          String?
  createdById           String?
  createdBy             User?    @relation("LeaseComplianceIssueCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById           String?
  updatedBy             User?    @relation("LeaseComplianceIssueUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  notes                 LeaseComplianceIssueNote[]
  photos                LeaseComplianceIssuePhoto[]
  noticeActions         LeaseComplianceNoticeAction[]
  persistenceChecks     LeaseCompliancePersistenceCheck[]

  @@index([propertyId, isArchived, status, createdAt])
  @@index([propertyId, unitId, createdAt])
  @@index([propertyId, noticeStage, createdAt])
  @@index([propertyId, priority, createdAt])
  @@index([propertyId, assignedUserId, isArchived, status])
  @@index([propertyMapId])
}

model LeaseComplianceIssueNote {
  id           String                @id @default(cuid())
  issueId      String
  issue        LeaseComplianceIssue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  propertyId   String
  property     Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  authorUserId String?
  author       User?                 @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  authorName   String
  body         String
  createdAt    DateTime              @default(now())

  @@index([issueId, createdAt])
  @@index([propertyId, createdAt])
}

model LeaseComplianceIssuePhoto {
  id           String                @id @default(cuid())
  issueId      String
  issue        LeaseComplianceIssue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  propertyId   String
  property     Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  uploadedById String?
  uploadedBy   User?                 @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  uploaderName String
  photoCategory String               @default("GENERAL")
  caption      String?
  originalName String
  storedName   String                @unique
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime              @default(now())

  @@index([issueId, createdAt])
  @@index([propertyId, createdAt])
}

model LeaseComplianceNoticeAction {
  id           String                @id @default(cuid())
  issueId      String
  issue        LeaseComplianceIssue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  propertyId   String
  property     Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  actedById    String?
  actedBy      User?                 @relation(fields: [actedById], references: [id], onDelete: SetNull)
  actedByName  String
  action       String
  noticeStage  String
  notes        String?
  createdAt    DateTime              @default(now())

  @@index([issueId, createdAt])
  @@index([propertyId, createdAt])
}

model LeaseCompliancePersistenceCheck {
  id           String                @id @default(cuid())
  issueId      String
  issue        LeaseComplianceIssue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  propertyId   String
  property     Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  checkedById  String?
  checkedBy    User?                 @relation(fields: [checkedById], references: [id], onDelete: SetNull)
  checkedByName String
  stillPersists Boolean              @default(true)
