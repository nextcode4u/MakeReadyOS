  defaultCents Int?
  description String?
  isActive    Boolean  @default(true)
  isArchived  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  attachments ItemAttachment[]

  @@unique([propertyId, name])
  @@index([propertyId, isArchived, sortOrder])
}

model ChecklistInstance {
  id         String                 @id @default(cuid())
  itemId     String
  item       MakeReadyItem          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property               @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  templateId String?
  template   ChecklistTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  name       String
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  items      ChecklistInstanceItem[]

  @@index([itemId, createdAt])
  @@index([propertyId, createdAt])
}

model ChecklistInstanceItem {
  id            String             @id @default(cuid())
  instanceId    String
  instance      ChecklistInstance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  title         String
  notes         String?
  sortOrder     Int                @default(0)
  required      Boolean            @default(true)
  dueOffsetDays Int?
  tradeCategory String?
  completed     Boolean            @default(false)
  completedAt   DateTime?
  completedById String?
  completedBy   User?              @relation(fields: [completedById], references: [id], onDelete: SetNull)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([instanceId, sortOrder])
  @@index([instanceId, completed, sortOrder])
}
