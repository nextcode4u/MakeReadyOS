{
  "name": "makereadyos-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --skip-generate",
    "db:deploy": "prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "seed": "tsx src/seed.ts",
    "seed:large": "tsx src/seedLarge.ts",
    "automations:run": "tsx src/runScheduledAutomations.ts",
    "analytics:snapshot": "tsx src/runAnalyticsSnapshot.ts",
    "webhooks:run": "tsx src/runWebhookDeliveries.ts",
    "uploads:route-existing": "tsx src/routeExistingUploads.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@prisma/client": "^6.8.2",
    "csv-stringify": "^6.5.2",
    "fastify": "^5.8.5",
    "nodemailer": "^6.10.1",
    "puppeteer-core": "^24.43.1",
    "yazl": "^3.3.1",
    "zod": "^3.25.28",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/nodemailer": "^6.4.24",
    "@types/yazl": "^3.3.1",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
