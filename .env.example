# Copy this file to .env before running MakeReadyOS.
# Change POSTGRES_PASSWORD, ADMIN_PASSWORD, and SESSION_COOKIE_SECRET before real use.
# Demo user credentials are for local evaluation only.

POSTGRES_DB=makereadyos
POSTGRES_USER=makeready
POSTGRES_PASSWORD=ChangeThisPostgres!23456
DATABASE_URL=postgresql://makeready:ChangeThisPostgres!23456@db:5432/makereadyos?schema=public
API_PORT=4000
WEB_PORT=8080
VITE_API_BASE_URL=/api
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisAdmin!23456
DEMO_TECH_EMAIL=tech@example.com
DEMO_TECH_PASSWORD=ChangeThisTech!23456
DEMO_LEASING_EMAIL=leasing@example.com
DEMO_LEASING_PASSWORD=ChangeThisLeasing!23456
DEMO_CLEANER_EMAIL=cleaner@example.com
DEMO_CLEANER_PASSWORD=ChangeThisCleaner!23456
# Set true only when you want sample properties, units, and make-ready turns.
# Leave false for first-run/blank-slate testing; baseline labels, columns,
# checklist templates, and schedule tracks are still created.
SEED_DEMO_DATA=false
SESSION_COOKIE_SECRET=ChangeThisSessionCookieSecretAtLeast32Chars
# Optional but recommended before enabling webhook delivery. If omitted, MakeReadyOS
# derives webhook secret encryption from SESSION_COOKIE_SECRET.
WEBHOOK_SECRET_ENCRYPTION_KEY=ChangeThisWebhookEncryptionKeyAtLeast32Chars
WEBHOOK_DELIVERY_BATCH_SIZE=25
WEBHOOK_DELIVERY_TIMEOUT_MS=5000
WEBHOOK_DELIVERY_MAX_ATTEMPTS=5
WEBHOOK_AUTO_DISABLE_FAILURES=0
# Keep true for trusted local/NAS/self-hosted integrations. For internet-facing
# deployments, set false to block localhost/private/link-local webhook targets.
WEBHOOK_ALLOW_PRIVATE_URLS=true
# Comma-separated hosts/IPs that stay allowed when private URL blocking is on.
WEBHOOK_ALLOWED_HOSTS=
SESSION_COOKIE_NAME=makereadyos_session
SESSION_COOKIE_SAME_SITE=lax
SESSION_TTL_DAYS=7
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
API_TOKEN_RATE_LIMIT_MAX=300
API_TOKEN_RATE_LIMIT_WINDOW_MINUTES=15
CORS_ORIGIN=http://localhost:8080,http://localhost:5173
BACKUP_RETENTION_DAYS=14
AUTOMATION_NOTE_COOLDOWN_HOURS=24
UPLOAD_DIR=/app/uploads
# Leave as uploads_data for Docker's managed volume, or set an absolute host/NAS path
# such as /mnt/makereadyos/uploads. Keep UPLOAD_DIR=/app/uploads inside the container.
UPLOADS_HOST_PATH=uploads_data
# 0 disables MakeReadyOS' per-file API limit. External reverse proxies, browsers,
# available disk space, and mobile memory can still limit very large uploads.
MAX_UPLOAD_MB=0
LARGE_SEED_COUNT=250
LARGE_SEED_PREFIX=LOAD
ENABLE_API_TIMING_LOGS=false
