# Copy this file to .env before running MakeReadyOS.
# Change POSTGRES_PASSWORD, ADMIN_PASSWORD, and SESSION_COOKIE_SECRET before real use.
# Demo user credentials are for local evaluation only.

POSTGRES_DB=makereadyos
POSTGRES_USER=makeready
POSTGRES_PASSWORD=ChangeThisPostgres!23456
DATABASE_URL=postgresql://makeready:ChangeThisPostgres!23456@db:5432/makereadyos?schema=public
API_PORT=4000
WEB_PORT=8080
VITE_API_BASE_URL=/api
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisAdmin!23456
DEMO_TECH_EMAIL=tech@example.com
DEMO_TECH_PASSWORD=ChangeThisTech!23456
DEMO_LEASING_EMAIL=leasing@example.com
DEMO_LEASING_PASSWORD=ChangeThisLeasing!23456
DEMO_CLEANER_EMAIL=cleaner@example.com
DEMO_CLEANER_PASSWORD=ChangeThisCleaner!23456
SESSION_COOKIE_SECRET=ChangeThisSessionCookieSecretAtLeast32Chars
SESSION_COOKIE_NAME=makereadyos_session
SESSION_COOKIE_SAME_SITE=lax
SESSION_TTL_DAYS=7
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
API_TOKEN_RATE_LIMIT_MAX=300
API_TOKEN_RATE_LIMIT_WINDOW_MINUTES=15
CORS_ORIGIN=http://localhost:8080,http://localhost:5173
BACKUP_RETENTION_DAYS=14
AUTOMATION_NOTE_COOLDOWN_HOURS=24
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=15
LARGE_SEED_COUNT=250
LARGE_SEED_PREFIX=LOAD
ENABLE_API_TIMING_LOGS=false
